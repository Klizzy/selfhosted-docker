# User/Group ID on the host (run `id` to check)
PUID=
PGID=

# Sonoff Dongle Max device path
# Find with: ls -la /dev/serial/by-id/
# Always use /dev/serial/by-id/ path, never /dev/ttyACM0
ZIGBEE_DEVICE=

# Gateway IP for network-check healthcheck (ping target on boot)
GATEWAY_IP=

# Backup config
BACKUP_DIR=
BACKUP_KEEP_COUNT=8
